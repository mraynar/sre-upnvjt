generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ENUMS (Standarisasi Data)
// ==========================================
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ==========================================
// 2. DYNAMIC RBAC & ORGANIZATION STRUCTURE
// ==========================================
model Department {
  id          Int        @id @default(autoincrement())
  name        String     @unique // Misal: "Finance", "BPH", "Media Creative"
  code        String     @unique // Misal: "FIN", "BPH", "MED"
  
  divisions   Division[]
  users       User[]
  projects    Project[]
}

model Division {
  id           Int        @id @default(autoincrement())
  name         String     // Misal: "Visual Design", "Public Relations"
  departmentId Int
  
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  users        User[]
}

model Role {
  id          Int        @id @default(autoincrement())
  name        String     @unique // Misal: "SUPER_ADMIN", "Manager of Finance", "Staff of PR"
  permissions Json       // JSON berisi object izin e.g., {"users": ["create", "read", "update", "delete"], "finance": ["read"]}
  
  users       User[]
}

// ==========================================
// 3. USER & MANAJEMEN SDM
// ==========================================
model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  password     String
  npm          String?    @unique // Nomor Induk Mahasiswa
  positionName String?    // Jabatan spesifik jika perlu, e.g. "Ketua Departemen"
  isActive     Boolean    @default(true)

  // Relasi RBAC & Struktur Organisasi
  roleId       Int
  departmentId Int?
  divisionId   Int?

  role         Role        @relation(fields: [roleId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  division     Division?   @relation(fields: [divisionId], references: [id])

  // Relasi: Satu User bisa punya banyak data di tabel lain (1:N)
  committees   Committee[]
  attendances  Attendance[]
  articles     Article[]
  finances     Finance[]
  loans        InventoryLoan[]
  createdSessions AttendanceSession[] @relation("SessionCreator")

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ==========================================
// 4. MANAJEMEN PROKER & KEPANITIAAN
// ==========================================
model Project {
  id           Int            @id @default(autoincrement())
  title        String         // Nama proker (misal: "SRE Mengajar")
  description  String?        @db.Text
  departmentId Int            // Departemen penanggung jawab
  startDate    DateTime
  endDate      DateTime?
  status       ApprovalStatus @default(PENDING)

  department   Department     @relation(fields: [departmentId], references: [id])

  // Relasi (1:N)
  committees   Committee[]
  attendanceSessions AttendanceSession[]
  finances     Finance[]      // Anggaran spesifik proker ini

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// Tabel Pivot (M:N) menghubungkan User & Project untuk struktur Kepanitiaan
model Committee {
  id        Int      @id @default(autoincrement())
  userId    Int
  projectId Int
  role      String   // Posisi di kepanitiaan (misal: "Ketua Pelaksana", "Divisi Acara")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId]) // 1 user hanya bisa punya 1 role spesifik per proker
}

// ==========================================
// 5. ABSENSI & KEHADIRAN
// ==========================================
model AttendanceSession {
  id          Int          @id @default(autoincrement())
  title       String       // e.g. "Rapat Pleno 1"
  date        DateTime     @default(now())
  isActive    Boolean      @default(true)
  createdById Int
  projectId   Int?         // Optional: If this session is for a specific project

  createdBy   User         @relation("SessionCreator", fields: [createdById], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  attendances Attendance[]
}

model Attendance {
  id          Int               @id @default(autoincrement())
  sessionId   Int
  userId      Int
  status      String            // "HADIR", "IZIN", "SAKIT", "ALFA"
  proofUrl    String?           // Link to proof of absence
  date        DateTime          @default(now())
  
  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
}

// ==========================================
// 6. MANAJEMEN KEUANGAN (CASHFLOW)
// ==========================================
model Finance {
  id          Int             @id @default(autoincrement())
  title       String          // Misal: "Uang Kas Bulan Mei", "Beli Konsumsi Rapat"
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType // INCOME / EXPENSE
  proofUrl    String?         // Link foto struk/bukti transfer
  date        DateTime        @default(now())

  loggedById  Int             // Siapa (staf Finance) yang mencatat
  projectId   Int?            // Opsional: Jika pengeluaran ini milik proker tertentu

  loggedBy    User            @relation(fields: [loggedById], references: [id])
  project     Project?        @relation(fields: [projectId], references: [id])
}

// ==========================================
// 7. KONTEN & MEDIA (CMS UNTUK WEB PUBLIK)
// ==========================================
model Article {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique // URL ramah SEO, misal: /blog/energi-terbarukan
  content      String   @db.Text
  excerpt      String?  @db.Text
  thumbnailUrl String?
  isPublished  Boolean  @default(false)
  
  authorId     Int
  author       User     @relation(fields: [authorId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==========================================
// 8. INVENTARIS & PEMINJAMAN BARANG
// ==========================================
model Inventory {
  id          Int      @id @default(autoincrement())
  name        String   // Misal: "Proyektor Epson", "Solder Listrik"
  code        String?
  category    String   @default("GENERAL")
  quantity    Int      @default(1)
  condition   String   @default("GOOD")
  location    String?
  isAvailable Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  loans       InventoryLoan[]
}

model InventoryLoan {
  id          Int            @id @default(autoincrement())
  itemId      Int
  userId      Int
  quantity    Int
  status      ApprovalStatus @default(PENDING) // PENDING, APPROVED, COMPLETED (Sudah dikembalikan)
  borrowDate  DateTime       @default(now())
  returnDate  DateTime?

  item        Inventory      @relation(fields: [itemId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
}

// ==========================================
// 9. BANK DATA (DOKUMEN TERPUSAT)
// ==========================================
model Document {
  id          Int      @id @default(autoincrement())
  title       String   // Misal: "SOP Media Creative", "AD/ART"
  url         String
  type        String   @default("OTHER")
  description String?  @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 10. ACTIVITY (KEGIATAN/PROGRAM BESAR)
// ==========================================
model Activity {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  imageUrl    String?
  isPublished Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 11. MERCHANDISE (TOKO SRE)
// ==========================================
model Merchandise {
  id          Int      @id @default(autoincrement())
  name        String
  price       Decimal  @db.Decimal(10, 2)
  description String   @db.Text
  imageUrl    String?
  linkUrl     String?  // Link ke Tokopedia/Shopee/WhatsApp
  isAvailable Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}